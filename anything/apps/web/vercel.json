{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "crons": [
    {
      "path": "/api/admin/send-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
